generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model usuario {
  id                   Int                 @id @default(autoincrement())
  nombre               String              @db.VarChar(100)
  correo               String              @unique @db.VarChar(120)
  imagen               String?             @db.VarChar(255)
  rol                  Rol
  telefono             String?             @db.VarChar(20)
  password             String              @db.VarChar(255)
  emailVerified        DateTime?
  passwordResetToken   String?             @db.VarChar(255)
  passwordResetExpires DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  activosResponsable   activo_fijo[]       @relation("ResponsableActivo")
  historialMovimientos historial_activos[] @relation("UsuarioHistorialActivo")
  reportesGenerados    reporte[]           @relation("UsuarioReporte")
}

model activo_fijo {
  id                   Int                 @id @default(autoincrement())
  numeroControl        String              @db.VarChar(100)
  descripcionActivo    String              @map("descripcion_activo") @db.VarChar(150)
  tipoEquipo           TipoEquipoActivo    @map("tipo_equipo")
  existencia           Int                 @default(1)
  medidas              String?             @db.VarChar(100)
  modeloMarca          String?             @map("modelo_marca") @db.VarChar(150)
  numeroSerie          String?             @unique @map("numero_serie") @db.VarChar(100)
  condicionesActivo    String?             @map("condiciones_activo") @db.VarChar(150)
  observaciones        String?             @db.Text
  imagenActivo         String?             @map("imagen_activo") @db.VarChar(255)

  sucursal             Sucursal
  ubicacion            String?             @db.VarChar(150)

  responsableDirectoId Int?
  responsableDirecto   usuario?            @relation("ResponsableActivo", fields: [responsableDirectoId], references: [id])

  status               EstadoActivo        @default(ACTIVO)

  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  historialMovimientos historial_activos[] @relation("ActivoHistorial")

  @@index([numeroControl])
  @@index([responsableDirectoId], map: "activo_fijo_responsableDirectoId_fkey")
  @@index([sucursal])
  @@index([tipoEquipo])
}

model historial_activos {
  id             Int             @id @default(autoincrement())
  activoId       Int
  numeroControl  String          @db.VarChar(100)
  descripcion    String?         @db.VarChar(150)
  tipoMovimiento TipoMovimiento
  detalle        String?         @db.Text
  sucursal       Sucursal
  usuarioId      Int?
  usuarioNombre  String?         @db.VarChar(100)
  fecha          DateTime        @default(now())

  activo         activo_fijo     @relation("ActivoHistorial", fields: [activoId], references: [id], onDelete: Cascade)
  usuario        usuario?        @relation("UsuarioHistorialActivo", fields: [usuarioId], references: [id])

  @@index([activoId])
  @@index([sucursal])
  @@index([usuarioId])
  @@index([tipoMovimiento])
  @@index([fecha])
}

model reporte {
  id            Int         @id @default(autoincrement())
  nombreArchivo String      @db.VarChar(255)
  tipoArchivo   TipoReporte
  rutaArchivo   String      @db.VarChar(255)
  sucursal      Sucursal?
  modulo        String?     @db.VarChar(100)
  creadoPorId   Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  creadoPor     usuario?    @relation("UsuarioReporte", fields: [creadoPorId], references: [id])

  @@index([sucursal])
  @@index([creadoPorId])
  @@index([createdAt])
}

enum Rol {
  ADMINISTRADOR
  INVENTARIOS
  AUXILIAR_INVENTARIOS
  CONSULTA
}

enum Sucursal {
  TAPACHULA
  TOSCANA
  CIUDAD_HIDALGO
  TUXTLA_GUTIERREZ
  OFICINAS_ADMINISTRATIVAS
  ALMACEN_CIUDAD_HIDALGO
  ALMACEN_TUXTLA_GUTIERREZ
}

enum EstadoActivo {
  ACTIVO
  INACTIVO
  MANTENIMIENTO
  BAJA
}

enum TipoMovimiento {
  ALTA
  EDICION
  BAJA
  CAMBIO_STATUS
  CAMBIO_UBICACION
  TRANSFERENCIA
}

enum TipoEquipoActivo {
  EQUIPO_MOBILIARIO
  EQUIPO_OFICINA
  EQUIPO_REPARTO
  EQUIPO_TRANSPORTE
}

enum TipoReporte {
  EXCEL
  PDF
}