{
  "name": "inventario_activos_gyd",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de inventario de activos de Distribución G&D",
  "author": "Kevin Castillo",
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "electron": "electron .",
    "desktop": "npm run build && npm run electron",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.gyd.inventarioactivos",
    "productName": "Inventario Activos GYD",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron-main.js",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "prisma/**/*",
      "build/**/*",
      "package.json",
      "auth.ts",
      ".env"
    ],
    "extraMetadata": {
      "main": "electron-main.js"
    },
    "win": {
      "target": "nsis",
      "icon": "build/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Inventario Activos GYD"
    }
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.8.0",
    "@headlessui/react": "^2.2.4",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tailwindcss/postcss": "^4.0.10",
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "echarts": "^5.6.0",
    "embla-carousel-react": "^8.5.2",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.477.0",
    "next": "^14.2.23",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.4",
    "nodemailer": "^6.10.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-day-picker": "8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-player": "^2.16.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.3",
    "sharp": "^0.34.2",
    "sonner": "^2.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@prisma/client": "^6.13.0",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8",
    "eslint": "^8",
    "eslint-config-next": "14.2.16",
    "postcss": "^8",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.0.10",
    "typescript": "^5"
  }
}
